# Example configuration for the LED Display Controller.
# Copy to config.yaml and adjust paths/pins for your setup.

mqtt:
  host: localhost
  port: 1883
  # Home Assistant's built-in Mosquitto broker add-on requires auth by default
  # (it doesn't accept anonymous connections) — set these to a valid HA user
  # or a dedicated MQTT user you create for the broker. Omit both if your
  # broker allows anonymous connections.
  # username: led-controller
  # password: change-me

relay:
  backend: mock  # "gpio" on the Pi, "mock" for local development
  # BCM numbering. GPIO0 (physical pin 27, the HAT ID EEPROM pin) is not claimed by any
  # of the 3 parallel chains in rpi-rgb-led-matrix's "regular" mapping, which Adafruit's
  # RGB Matrix Bonnets use — GPIO2-27 are all matrix signals on chain 1, 2, or 3, even for
  # chains you haven't physically populated. Verify against your specific bonnet/HAT.
  pin: 0
  # Set to true if your relay board is active-low (LOW energizes the relay) -- most
  # cheap boards are. Wrong polarity here means the PSU switches on the instant the
  # controller starts, before any Power On command.
  active_low: false

process_terminate_timeout: 5.0  # seconds to wait for SIGTERM before SIGKILL

# Raw RGBMatrixOptions attribute overrides (not CLI flag names -- see
# led_controller/config.py's MatrixConfig for why), rendered into a single
# `--matrix-options '<json>'` argument wherever a command has the
# {matrix_options} placeholder. Every field here is optional; anything you
# don't set keeps rpi-rgb-led-matrix's own default. See
# https://github.com/hzeller/rpi-rgb-led-matrix/blob/master/bindings/python/samples/samplebase.py
# for the full set of RGBMatrixOptions attributes this can carry.
matrix:
  rows: 64
  cols: 128
  chain_length: 2
  parallel: 2
  multiplexing: 0
  pwm_bits: 5
  pwm_dither_bits: 1
  brightness: 100
  gpio_slowdown: 1
  show_refresh_rate: true
  limit_refresh_rate_hz: 190

# System animations: run like any other program, but not user-selectable.
# idle/shutdown live in programs/ and need the rgbmatrix Python
# extension built from the third_party/rpi-rgb-led-matrix submodule first —
# see the top-level README.md. Matrix hardware flags (--led-rows, --led-cols,
# --led-gpio-mapping, etc.) default to a single 64x32 chain on an Adafruit
# Triple LED Matrix Bonnet; pass them explicitly here to override.
#
# Use {python} rather than a bare "python3" for any Python program -- it expands to
# the exact interpreter running the controller (its own sys.executable), so every
# launched program uses the same venv the controller itself does, including
# rgbmatrix. A bare "python3" is resolved via $PATH at launch time instead, which
# under systemd (or sudo) often silently picks a *different* Python than your venv's
# -- see README.md's rgbmatrix/venv troubleshooting notes.
system:
  idle: '{python} programs/idle.py --label "LED DISPLAY"'
  shutdown: '{python} programs/shutdown.py --message "Goodbye!"'

programs:

  weather:
    name: Weather
    command: "{python} programs/weather.py"

  clock:
    name: Clock
    command: "{python} programs/clock.py"

  # db-display (https://github.com/moma03/db-display) reads its own --eva flag,
  # falling back to config.json's "database.eva" when it's not given -- see
  # LoadConfigWithCliOverrides's --led-* equivalent for the matrix options. The
  # subprogram id doubles as the station's EVA number here since db-display
  # only cares about that raw value, not a name -- {subprogram} works with any
  # opaque id, it doesn't have to be a slug like trainboard's above. It's not a
  # Python program, so no {python} here -- run it with whatever interpreter/binary
  # it actually needs, same as any non-Python program.
  db_display:
    name: Train Departures
    command: /path/to/db-display/db_display --eva {subprogram}
    subprograms:
      "8000297":
        name: Frankfurt Hbf
      "8000105":
        name: Berlin Hbf
