# Copy to /etc/led-panel-emergency-restart.env and adjust to match your config.yaml's
# mqtt: block. Only needed if your broker isn't on localhost:1883 with no auth.
# For me its IP and Port of the MQTT broker of my HomeAssistant instance
LED_MQTT_HOST=localhost
LED_MQTT_PORT=1883
#LED_MQTT_USERNAME=led-controller
#LED_MQTT_PASSWORD=change-me
